{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "guest-js",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["guest-js/**/*"],
  "exclude": ["node_modules", "dist"]
}
